generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  MANAGER
  OPERACIONES
  FRANQUICIA
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum VisitStatus {
  PENDIENTE
  APROBADA
  COORDINADA
  RECHAZADA
  COMPLETADA
}

enum ManualItemType {
  PDF
  VIDEO
  TEXT
  IMAGE
}

// ─── Users & Auth ───────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(FRANQUICIA)
  avatar    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  franchise   Franchise? @relation(fields: [franchiseId], references: [id])
  franchiseId String?

  tickets        Ticket[]
  ticketMessages TicketMessage[]
  visits         VisitRequest[]
  audits         Audit[]
}

// ─── Franchises ─────────────────────────────────────────

model Franchise {
  id              String  @id @default(uuid())
  name            String
  location        String  @default("")
  zona            String  @default("")
  barrio          String  @default("")
  address         String  @default("")
  city            String  @default("")
  phone           String  @default("")
  whatsapp1       String  @default("")
  whatsapp2       String  @default("")
  googleMaps      String  @default("")
  email           String  @default("")
  responsable     String  @default("")
  status          String  @default("activa")
  openDate        String  @default("")
  employees       Int     @default(0)
  lastAuditScore  Float?
  monthlyBilling  Float   @default(0)
  notes           String  @default("")
  score           Float   @default(0)
  active          Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  tickets   Ticket[]
  visits    VisitRequest[]
  audits    Audit[]
  billing   BillingData[]
  royalties Royalty[]
  ads       AdIncome[]

  zone   Zone?   @relation(fields: [zoneId], references: [id])
  zoneId String?
}

// ─── Expansión / Análisis de Zonas ──────────────────────

model Zone {
  id                  String  @id @default(uuid())
  nombre              String
  provincia           String  @default("")
  partidoComuna       String  @default("")
  barrio              String  @default("")
  poblacion           Int     @default(0)
  densidadHabKm2      Float   @default(0)
  ingresoPromedio     Float   @default(0)
  edadMediana         Float   @default(0)
  nivelSocioeconomico String  @default("")
  oficinasCercanas    Int     @default(0)
  competenciaSushi    Int     @default(0)
  notas               String  @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  franchises Franchise[]

  @@unique([provincia, partidoComuna, barrio, nombre])
}

model BillingData {
  id              String   @id @default(uuid())
  periodo         String
  ventasBrutas    Float    @default(0)
  transacciones   Int      @default(0)
  ticketPromedio  Float    @default(0)
  notas           String   @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  franchise   Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  franchiseId String

  @@unique([franchiseId, periodo])
  @@index([franchiseId])
}

model Royalty {
  id              String   @id @default(uuid())
  periodo         String
  monto           Float    @default(0)
  baseFacturacion Float    @default(0)
  porcentaje      Float    @default(0)
  estado          String   @default("pendiente")
  cobro           String   @default("JIRONOSRL")
  notas           String   @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  franchise   Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  franchiseId String

  @@unique([franchiseId, periodo])
  @@index([franchiseId])
}

model AdIncome {
  id              String   @id @default(uuid())
  periodo         String
  monto           Float    @default(0)
  baseFacturacion Float    @default(0)
  porcentaje      Float    @default(0)
  estado          String   @default("pendiente")
  cobro           String   @default("JIRONOSRL")
  notas           String   @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  franchise   Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  franchiseId String

  @@unique([franchiseId, periodo])
  @@index([franchiseId])
}

// ─── Manual Operativo ───────────────────────────────────

model Category {
  id          String  @id @default(uuid())
  title       String  @unique
  description String  @default("")
  icon        String  @default("FileText")
  color       String  @default("text-slate-400")
  bg          String  @default("bg-slate-400/10")
  isDefault   Boolean @default(false)

  createdAt DateTime @default(now())

  items ManualItem[]
}

model ManualItem {
  id          String         @id @default(uuid())
  title       String
  description String
  type        ManualItemType
  fileName    String?
  fileUrl     String?
  textContent String?
  author      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String
}

model ManualPdf {
  id         String   @id @default(uuid())
  fileName   String
  fileUrl    String
  size       String
  uploadedAt DateTime @default(now())
  active     Boolean  @default(true)
}

// ─── Tickets ────────────────────────────────────────────

model Ticket {
  id           String         @id @default(uuid())
  title        String
  description  String
  status       TicketStatus   @default(OPEN)
  priority     TicketPriority @default(MEDIUM)
  category     String
  responseTime String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  franchise   Franchise? @relation(fields: [franchiseId], references: [id])
  franchiseId String?

  assignedAgent  String?
  assignedAvatar String?

  messages TicketMessage[]
}

model TicketMessage {
  id        String   @id @default(uuid())
  content   String
  role      String
  createdAt DateTime @default(now())

  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId String

  author   User?   @relation(fields: [authorId], references: [id])
  authorId String?
}

// ─── Visitas ────────────────────────────────────────────

model VisitRequest {
  id            String      @id @default(uuid())
  motivo        String
  detalle       String
  urgency       String      @default("media")
  status        VisitStatus @default(PENDIENTE)
  scheduledDate DateTime?
  assignedTo    String?
  internalNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  franchise   Franchise @relation(fields: [franchiseId], references: [id])
  franchiseId String

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String
}

// ─── Auditorías ────────────────────────────────────────

model Audit {
  id                    String   @id @default(uuid())
  fecha                 DateTime
  turno                 String
  tipoAuditoria         String
  localNotificado       String
  cocinaScores          String   @default("{}") // JSON: scores por categoría
  cajasScores           String   @default("{}") // JSON: scores por categoría
  cocinaTotal           Float    @default(0)
  cocinaMax             Float    @default(0)
  cajasTotal            Float    @default(0)
  cajasMax              Float    @default(0)
  cocinaPercent         Float    @default(0)
  cajasPercent          Float    @default(0)
  hallazgosCocina       String   @default("")
  hallazgosCaja         String   @default("")
  accionesCorrectivas       String   @default("")
  accionesCorrectivasStatus String   @default("{}")
  accionesCorrectivasFechaVencimiento DateTime?
  nivelUrgencia         String   @default("")
  localObservado        String   @default("")
  observaciones         String   @default("")
  firmaResponsable      String   @default("")
  firmaConsultor        String   @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  franchise   Franchise @relation(fields: [franchiseId], references: [id])
  franchiseId String

  auditor   User   @relation(fields: [auditorId], references: [id])
  auditorId String
}

// ─── Role Permissions Config ────────────────────────────

model RolePermissionsConfig {
  id          String   @id @default("singleton")
  permissions String   @default("{}")
  updatedAt   DateTime @updatedAt
}

// ─── Audit Config ───────────────────────────────────────

model AuditConfig {
  id               String   @id @default("singleton")
  cocinaCategories String   @default("[]")
  cajasCategories  String   @default("[]")
  updatedAt        DateTime @updatedAt
}

// ─── Ono Config ─────────────────────────────────────────

model OnoConfig {
  id               String   @id @default("singleton")
  customPrompt     String   @default("")
  quickCategories  String   @default("[]")
  manualTopics     String   @default("[]")
  suggestedQueries String   @default("[]")
  temperatureRef   String   @default("[]")
  updatedAt        DateTime @updatedAt
}

model ContextFile {
  id            String   @id @default(uuid())
  fileName      String
  size          String
  extractedText String
  uploadedAt    DateTime @default(now())
}
